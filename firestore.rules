rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Aethera user profiles — users can only read/write their own data
    match /aethera_users/{uid} {
      // Read: only your own profile
      allow read: if request.auth != null && request.auth.uid == uid;

      // Create: only your own profile
      allow create: if request.auth != null && request.auth.uid == uid;

      // Update: only your own profile, and cannot set is_premium or trial_start
      allow update: if request.auth != null
        && request.auth.uid == uid
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['is_premium', 'trial_start']));

      // Delete: not allowed from client — only backend/admin
      allow delete: if false;
    }

    // Deny all access to any other collection by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
