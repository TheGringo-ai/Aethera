rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Aethera user profiles — users can only read/write their own data
    match /aethera_users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Prevent users from setting is_premium directly (must come from backend/admin)
      allow update: if request.auth != null
        && request.auth.uid == uid
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['is_premium', 'trial_start']));
    }
  }
}
